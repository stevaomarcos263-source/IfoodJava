# ==========================================
# Java (Compilação e Execução)
# ==========================================
*.class
*.log
*.jar
*.war
*.ear
/target/
/bin/
/out/

# ==========================================
# IntelliJ IDEA
# ==========================================
.idea/
*.iml
*.iws
*.ipr
out/

# ==========================================
# Controle de Versão e Arquivos do Sistema
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Banco de Dados (MySQL / Configurações locais)
# ==========================================
# Esconde arquivos de propriedades que possam conter sua senha do banco
*.properties
*.env
*.local

# Ignora dumps de backup do banco de dados que você possa gerar na raiz
*.sql
!/src/**/*.sql # Permite scripts SQL se eles estiverem dentro da pasta src (ex: migrations)

# ==========================================
# Arquivos JSON e Configurações de Ferramentas
# ==========================================
# Ignora arquivos JSON apenas na raiz e em outras pastas não autorizadas
*.json

# EXCEÇÕES: Força o Git a olhar dentro dessas pastas mesmo se tiverem JSONs
!/src/**
!/exemplos-json/**

# Bloqueia especificamente a pasta interna de dados locais do projeto
/src/main/resources/data/